{
  "name": "@identitate-md/logos",
  "version": "1.3.31",
  "description": "Logo-uri oficiale ale instituțiilor publice din Republica Moldova — Official logos of public institutions from the Republic of Moldova",
  "license": "MIT",
  "author": "IdentitateMD Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/identitate-md/identitate-md",
    "directory": "packages/logos"
  },
  "homepage": "https://identitate.md",
  "keywords": [
    "moldova",
    "logos",
    "institutions",
    "government",
    "branding",
    "svg",
    "visual-identity",
    "public-sector"
