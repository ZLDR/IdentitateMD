  "files": [
    "logos/**/*",
    "index.json",
    "identity-loader.js",
    "README.md",
    "LICENSE"
  ],
  "main": "index.json",
  "exports": {
    ".": "./index.json",
    "./loader": "./identity-loader.js",
    "./logos/*": "./logos/*"
