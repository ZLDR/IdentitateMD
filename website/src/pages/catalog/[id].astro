---
import CatalogPage from './index.astro';
import institutionIndex from '../../data/institutions-index.json';
import { buildCatalogPathMap } from '../../lib/helpers';
import type { Institution } from '../../types/institution';

export async function getStaticPaths() {
  const institutions = institutionIndex.institutions as unknown as Institution[];
  const catalogPathBySlug = buildCatalogPathMap(institutions);
  const ids = new Set<string>();

  for (const inst of institutions) {
    ids.add(catalogPathBySlug[inst.slug] || inst.slug);
    ids.add(inst.slug);
  }

  return [...ids].map((id) => ({
    params: { id },
    props: { initialPathId: id },
  }));
}

const { initialPathId } = Astro.props;
---

<CatalogPage initialPathId={initialPathId} />
